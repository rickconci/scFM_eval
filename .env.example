# Root for datasets: put .h5ad files here (or in subdirs); YAML dataset.path is relative to this
DATASETS_PATH=/path/to/your/datasets
# Root for model checkpoints; each model has its own subdir (STACK, scGPT, VCC_checkpoints, etc.)
MODEL_CHECKPOINTS=/path/to/your/model_checkpoints
# Where experiment outputs and embeddings are written
OUTPUT_PATH=/path/to/your/eval_output

# Omnicell: full path to checkpoint (set once; all Omnicell YAMLs use this)
OMNICELL_CHECKPOINT_PATH=/orcd/data/omarabu/001/Omnicell_datasets/protocol_embeddings/distribution_embeddings_results_13mar_epoch2.pkl
# Omnicell: optional override for checkpoint root if not using OMNICELL_CHECKPOINT_PATH (defaults to MODEL_CHECKPOINTS)
# OMNICELL_CHECKPOINTS_BASE=/path/to/omnicell_checkpoints
# Omnicell: cell-types repo root (e.g. .../cell-types) or package dir (.../cell-types/cell_types)
# OMNICELL_BASE_DIR=/path/to/cell-types
# Omnicell: dir containing protocol_embeddings/ (global_gene_mapping_v2_new.parquet, gene_manager_serialized.pkl)
# OMNICELL_DATA_DIR=/lotterlab/datasets/VCC/MODEL_CHECKPOINTS/VCC_checkpoints
# Optional: Python for Omnicell subprocess (e.g. cell-types–specific env); default is current Python
# OMNICELL_PYTHON=/path/to/your/SCFM_meta/bin/python

# Optional: for extractors with separate envs (see extractors/README.md)
# STACK_REPO_ROOT=/path/to/stack/repo
# STATE_REPO_PATH=/path/to/state/repo
# SCGPT_REPO_PATH=/path/to/scGPT/repo
# GENEFORMER_REPO_PATH=/path/to/Geneformer/repo
# UCE_REPO_PATH=/path/to/UCE/repo
# SCFM_EVAL_PARAMS_PATH=/path/to/yaml
